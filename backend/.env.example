APP_NAME=One More Restaurant Backend
APP_VERSION=0.1.0
API_PREFIX=/api
GOOGLE_ANALYTICS_ID=UA-XXXXXXX-X
FACEBOOK_ANALYTICS_TOKEN=your_facebook_token_here
CUSTOM_ANALYTICS_ENABLED=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
EXPRESS_PORT=3000

# Telegram Bot Alert Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email Alert SMTP Settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=user@example.com
SMTP_PASSWORD=your_smtp_password_here
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_TO_EMAIL=admin@example.com

